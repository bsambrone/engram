# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/engram
REDIS_URL=redis://localhost:6379/0

# API Keys
OPENAI_API_KEY=sk-...              # required — always needed for embeddings
ANTHROPIC_API_KEY=                  # optional — only needed if generation_provider is "anthropic"

# Encryption (generated by `engram init`)
ENGRAM_ENCRYPTION_KEY=

# LLM Generation
GENERATION_PROVIDER=openai          # "openai" or "anthropic"
GENERATION_MODEL=gpt-4.1            # model name for the chosen provider

# Processing
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
MEMORY_DECAY_HALFLIFE_DAYS=365
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Storage
PHOTO_STORAGE_DIR=~/.engram/photos

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MCP_TRANSPORT=stdio
LOG_LEVEL=INFO
