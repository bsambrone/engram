# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/engram
REDIS_URL=redis://localhost:6379/0

# API Keys
OPENAI_API_KEY=sk-...              # required — used for generation + embeddings

# Encryption (generated by `engram init`)
ENGRAM_ENCRYPTION_KEY=

# LLM Generation
GENERATION_PROVIDER=openai
GENERATION_MODEL=gpt-5.2

# Processing
CHUNK_SIZE_TOKENS=500
CHUNK_OVERLAP_TOKENS=50
MEMORY_DECAY_HALFLIFE_DAYS=365
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Storage
PHOTO_STORAGE_DIR=~/.engram/photos

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
MCP_TRANSPORT=stdio
LOG_LEVEL=INFO
